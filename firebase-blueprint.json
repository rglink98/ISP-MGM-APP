{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "photoURL": { "type": "string", "format": "uri" },
        "designation": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents an income, expense, or inter-cash transfer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense", "transfer"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["cash", "bank", "bkash", "merchant", "nagad", "other"] },
        "date": { "type": "string", "format": "date-time" },
        "detail": { "type": "string" },
        "createdBy": { "type": "string" },
        "fromAccount": { "type": "string" },
        "toAccount": { "type": "string" }
      },
      "required": ["type", "amount", "date", "createdBy"]
    },
    "Category": {
      "title": "Category",
      "description": "Represents a category for income or expense.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] }
      },
      "required": ["name", "type"]
    },
    "InventoryItem": {
      "title": "InventoryItem",
      "description": "Represents a product in the inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "valuePerUnit": { "type": "number" }
      },
      "required": ["name", "stock"]
    },
    "InventoryLog": {
      "title": "InventoryLog",
      "description": "Represents a log of product addition or usage.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "type": { "type": "string", "enum": ["add", "use"] },
        "quantity": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "detail": { "type": "string" },
        "createdBy": { "type": "string" }
      },
      "required": ["productId", "type", "quantity", "date", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial transactions."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Income and expense categories."
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory products."
    },
    "/inventoryLogs/{logId}": {
      "schema": "InventoryLog",
      "description": "Inventory transaction logs."
    }
  }
}
